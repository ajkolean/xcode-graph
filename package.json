{
  "name": "xcode-graph",
  "version": "1.34.5-4",
  "xcodegraph": "1.34.5",
  "description": "Interactive dependency graph visualization web component for Xcode projects",
  "license": "MIT",
  "homepage": "https://ajkolean.github.io/xcode-graph/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajkolean/xcode-graph.git"
  },
  "bugs": {
    "url": "https://github.com/ajkolean/xcode-graph/issues"
  },
  "keywords": [
    "xcode",
    "tuist",
    "dependency-graph",
    "web-component",
    "lit",
    "visualization"
  ],
  "packageManager": "pnpm@10.32.0",
  "type": "module",
  "main": "dist/xcodegraph.js",
  "module": "dist/xcodegraph.js",
  "types": "dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/xcodegraph.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "custom-elements.json",
    "web-types.json",
    "vscode.html-custom-data.json",
    "vscode.css-custom-data.json"
  ],
  "web-types": "web-types.json",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@zag-js/core": "^1.35.3",
    "@zag-js/vanilla": "^1.35.3",
    "colord": "^2.9.3",
    "d3-ease": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "elkjs": "^0.11.1",
    "focus-trap": "^8.0.0",
    "fuse.js": "^7.1.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "lit": "^3.3.2",
    "lit-html": "^3.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit-labs/compiler": "^1.1.2",
    "@lit-labs/signals": "^0.2.0",
    "@microsoft/api-extractor": "^7.57.6",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/file": "^12.0.1",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-quadtree": "^3.0.6",
    "@types/node": "^25.3.5",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@wc-toolkit/type-parser": "^1.2.0",
    "custom-element-jet-brains-integration": "^1.7.0",
    "custom-element-vs-code-integration": "^1.5.0",
    "jsdom": "^29.0.1",
    "knip": "^6.1.0",
    "oxc-minify": "^0.121.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.0.1",
    "ts-lit-plugin": "^2.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vite": "8.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "vitest-canvas-mock": "^1.1.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild:lib": "cem analyze",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build:api": "tsc -p tsconfig.api.json",
    "lint": "biome lint .",
    "lint:tokens": "./scripts/lint-tokens.sh",
    "format": "biome format --write .",
    "check": "biome check --write . && ./scripts/lint-tokens.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preversion": "cem analyze",
    "version": "git add custom-elements.json vscode.html-custom-data.json vscode.css-custom-data.json web-types.json",
    "prepublishOnly": "cem analyze",
    "analyze": "cem analyze",
    "analyze:check": "cem analyze && git diff --exit-code custom-elements.json vscode.html-custom-data.json vscode.css-custom-data.json web-types.json",
    "docs:dev": "pnpm typedoc && vitepress dev docs --port 5174",
    "docs:build": "pnpm typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs --port 5174",
    "docs:api": "typedoc",
    "docs:api:extract": "pnpm build:api && api-extractor run --local --verbose",
    "docs:api:extract:ci": "pnpm build:api && api-extractor run",
    "knip": "knip",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "version:sync": "./scripts/version-sync.sh"
  },
  "customElements": "custom-elements.json",
  "pnpm": {
    "overrides": {
      "vite": "8.0.3",
      "minimatch": ">=10.2.3"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@vaadin/vaadin-usage-statistics",
      "esbuild",
      "rs-module-lexer",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
