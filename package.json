{
  "name": "tuistgraph",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "type": "module",
  "dependencies": {
    "@zag-js/core": "^1.30.0",
    "@zag-js/store": "^1.30.0",
    "@zag-js/utils": "1.30.0",
    "lit": "^3.3.1",
    "zod": "^4.1.13",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@chromatic-com/playwright": "^0.12.7",
    "@chromatic-com/storybook": "^4.1.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@microsoft/api-extractor": "^7.55.1",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^10.1.1",
    "@storybook/addon-docs": "^10.1.1",
    "@storybook/addon-links": "^10.1.1",
    "@storybook/addon-mcp": "^0.1.4",
    "@storybook/addon-vitest": "^10.1.1",
    "@storybook/web-components": "^10.1.1",
    "@storybook/web-components-vite": "^10.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.10.1",
    "@vitest/browser-playwright": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "biome": "^0.3.3",
    "chromatic": "^13.3.4",
    "comlink": "^4.4.2",
    "depcheck": "^1.4.7",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^27.2.0",
    "shadow-dom-testing-library": "^1.13.1",
    "storybook": "^10.1.2",
    "typedoc": "^0.28.14",
    "vite": "7.2.4",
    "vitest": "^4.0.14"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "build:api": "tsc -p tsconfig.api.json",
    "lint": "biome lint .",
    "lint:tokens": "./scripts/lint-tokens.sh",
    "format": "biome format --write .",
    "check": "biome check --write . && ./scripts/lint-tokens.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "cem analyze",
    "docs": "typedoc",
    "docs:api": "pnpm build:api && api-extractor run --local --verbose",
    "docs:api:ci": "pnpm build:api && api-extractor run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook",
    "chromatic": "IS_CHROMATIC=true dotenv -e .env.local chromatic --only-changed"
  },
  "customElements": "custom-elements.json",
  "pnpm": {
    "overrides": {
      "valibot": ">=1.2.0"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@vaadin/vaadin-usage-statistics",
      "core-js",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "engines": {
    "pnpm": ">=10"
  }
}