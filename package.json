{
  "name": "xcode-graph",
  "version": "0.1.0",
  "xcodegraph": "1.34.5",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "module": "dist/xcodegraph.js",
  "exports": {
    ".": {
      "import": "./dist/xcodegraph.js"
    },
    "./dist/xcodegraph.js": "./dist/xcodegraph.js"
  },
  "files": [
    "dist/**/*.js",
    "custom-elements.json",
    "web-types.json",
    "vscode.html-custom-data.json",
    "vscode.css-custom-data.json"
  ],
  "web-types": "web-types.json",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lit-labs/observers": "^2.1.0",
    "@lit-labs/virtualizer": "^2.1.1",
    "@zag-js/core": "^1.35.2",
    "@zag-js/vanilla": "^1.35.2",
    "colord": "^2.9.3",
    "comlink": "^4.4.2",
    "d3-ease": "^3.0.1",
    "d3-force": "^3.0.0",
    "elkjs": "^0.11.0",
    "focus-trap": "^8.0.0",
    "lit": "^3.3.2",
    "lit-html": "^3.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit-labs/compiler": "^1.1.2",
    "@lit-labs/signals": "^0.2.0",
    "@microsoft/api-extractor": "^7.57.6",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/file": "^12.0.0",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.3.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "cem-plugin-expanded-types": "^1.4.0",
    "custom-element-jet-brains-integration": "^1.7.0",
    "custom-element-vs-code-integration": "^1.5.0",
    "depcheck": "^1.4.7",
    "jsdom": "^28.1.0",
    "rollup-plugin-minify-template-literals": "^1.1.7",
    "rollup-plugin-visualizer": "^7.0.0",
    "size-limit": "^12.0.0",
    "ts-lit-plugin": "^2.0.2",
    "typedoc": "^0.28.17",
    "vite": "7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "vitest-canvas-mock": "^1.1.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild:lib": "cem analyze",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build:api": "tsc -p tsconfig.api.json",
    "lint": "biome lint .",
    "lint:tokens": "./scripts/lint-tokens.sh",
    "format": "biome format --write .",
    "check": "biome check --write . && ./scripts/lint-tokens.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "cem analyze",
    "analyze:check": "cem analyze && git diff --exit-code custom-elements.json vscode.html-custom-data.json vscode.css-custom-data.json web-types.json",
    "docs:dev": "vitepress dev docs --port 5174",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 5174",
    "docs:api": "typedoc",
    "docs:api:extract": "pnpm build:api && api-extractor run --local --verbose",
    "docs:api:extract:ci": "pnpm build:api && api-extractor run",
    "depcheck": "depcheck",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "version:sync": "./scripts/version-sync.sh"
  },
  "customElements": "custom-elements.json",
  "pnpm": {
    "overrides": {
      "valibot": ">=1.2.0",
      "keygrip": "^1.1.0",
      "qs": ">=6.14.1",
      "minimatch": ">=10.2.3",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "koa": ">=2.16.4",
      "esbuild": ">=0.25.0",
      "lodash": ">=4.17.23",
      "markdown-it": ">=14.1.1",
      "diff@>=6.0.0 <8.0.3": ">=8.0.3"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@vaadin/vaadin-usage-statistics",
      "esbuild",
      "maplibre-gl",
      "unrs-resolver"
    ]
  },
  "engines": {
    "pnpm": ">=10"
  }
}
